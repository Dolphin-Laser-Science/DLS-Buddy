# Pin line endings for the double-click launchers so they work regardless of each
# machine's git autocrlf setting. A shell script with CRLF endings fails on macOS
# (bash chokes on the trailing \r), so the .command/.sh must always check out as LF;
# the Windows .bat wants CRLF.
*.command text eol=lf
*.sh      text eol=lf
*.bat     text eol=crlf

# PDFs are binary — never apply line-ending normalization (autocrlf would corrupt
# the byte stream on checkout). Covers the committed docs/*.pdf and the generated
# illustrated guide. `-text` keeps the system `diff: astextplain` textconv intact.
*.pdf     -text
